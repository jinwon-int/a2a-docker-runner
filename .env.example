# Runtime root on the worker host
A2A_DOCKER_RUNNER_ROOT=/var/lib/openclaw-a2a/tasks

# docker or podman. Auto-detected if empty.
A2A_DOCKER_RUNNER_ENGINE=

# Default task image used to execute task containers.
A2A_DOCKER_RUNNER_IMAGE=node:22-bookworm-slim

# Optional bounded build/revision metadata injected into task containers and
# propagated in safe evidence. Values must be public, compact, and secret-free.
# If BUILD_IMAGE is unset, the runner uses A2A_DOCKER_RUNNER_IMAGE as metadata.
# A2A_DOCKER_RUNNER_BUILD_VERSION=0.1.0
# A2A_DOCKER_RUNNER_BUILD_SOURCE=https://github.com/jinwon-int/a2a-docker-runner
# A2A_DOCKER_RUNNER_BUILD_REVISION=0123456789abcdef
# A2A_DOCKER_RUNNER_BUILD_BUILT_AT=2026-05-01T00:00:00Z
# A2A_DOCKER_RUNNER_BUILD_IMAGE=ghcr.io/jinwon-int/a2a-docker-runner:0123456789abcdef

# Optional GitHub token file mounted read-only into task containers.
A2A_DOCKER_RUNNER_GITHUB_TOKEN_FILE=/home/runner/.config/gh/hosts.yml

# Safe patch command for github-propose-patch default commands.
# Precedence: SCRIPT > JSON > TEMPLATE. Use synthetic examples only; do not commit secrets.
# SCRIPT is written to /work/patch-command.sh and executed without eval.
# A2A_DOCKER_RUNNER_PATCH_COMMAND_SCRIPT=

# JSON is converted into a safe argv/env script. Example:
# {"argv":["codex","exec","--full-auto","prompt"],"env":{"SAFE":"value"}}
# A2A_DOCKER_RUNNER_PATCH_COMMAND_JSON=

# Legacy escape hatch. Injected as A2A_PATCH_COMMAND and evaluated inside the container.
# Prefer SCRIPT or JSON for new rollouts.
# Claude-in-Docker commands and Claude credential mounts are blocked unless explicitly opted in.
# A2A_ALLOW_CLAUDE_IN_DOCKER=0
# Temporary legacy example only:
# A2A_ALLOW_CLAUDE_IN_DOCKER=1
# A2A_DOCKER_RUNNER_PATCH_COMMAND_TEMPLATE=claude --print --permission-mode bypassPermissions -p "$(cat /work/artifacts/prompt.md)"
# A2A_DOCKER_RUNNER_PATCH_COMMAND_TEMPLATE=
