# Runtime root on the worker host
A2A_DOCKER_RUNNER_ROOT=/var/lib/openclaw-a2a/tasks

# docker or podman. Auto-detected if empty.
A2A_DOCKER_RUNNER_ENGINE=

# Default task image. MVP can start with node:22-bookworm-slim.
A2A_DOCKER_RUNNER_IMAGE=node:22-bookworm-slim

# Optional GitHub token file mounted read-only into task containers.
A2A_DOCKER_RUNNER_GITHUB_TOKEN_FILE=/home/runner/.config/gh/hosts.yml

# Safe patch command for github-propose-patch default commands.
# Precedence: SCRIPT > JSON > TEMPLATE. Use synthetic examples only; do not commit secrets.
# SCRIPT is written to /work/patch-command.sh and executed without eval.
# A2A_DOCKER_RUNNER_PATCH_COMMAND_SCRIPT=

# JSON is converted into a safe argv/env script. Example:
# {"argv":["codex","exec","--full-auto","prompt"],"env":{"SAFE":"value"}}
# A2A_DOCKER_RUNNER_PATCH_COMMAND_JSON=

# Legacy escape hatch. Injected as A2A_PATCH_COMMAND and evaluated inside the container.
# Prefer SCRIPT or JSON for new rollouts.
# Example: claude --print --permission-mode bypassPermissions -p "$(cat /work/artifacts/prompt.md)"
# A2A_DOCKER_RUNNER_PATCH_COMMAND_TEMPLATE=
