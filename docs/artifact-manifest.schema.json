{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jinwon-int/a2a-docker-runner/docs/artifact-manifest.schema.json",
  "title": "A2A Docker Runner Artifact Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifactVersion", "schemaVersion", "manifestPath", "generatedAt", "status", "summary", "evidence", "artifacts"],
  "properties": {
    "artifactVersion": { "const": 1 },
    "schemaVersion": { "const": 1, "description": "Backward-compatible alias for older runner consumers." },
    "manifestPath": { "type": "string", "const": "artifacts/manifest.json" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "taskId": { "type": "string", "minLength": 1 },
    "repo": { "type": "string", "minLength": 1 },
    "branch": { "type": "string", "minLength": 1 },
    "prUrl": { "type": "string", "format": "uri" },
    "issueUrl": { "type": "string", "format": "uri" },
    "status": { "enum": ["done", "blocked", "failed", "budget_limited"] },
    "summary": { "type": "string", "minLength": 1, "maxLength": 1000 },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "label"],
        "properties": {
          "kind": { "enum": ["log", "test", "diff", "file"] },
          "label": { "type": "string", "minLength": 1 },
          "status": { "enum": ["passed", "failed", "blocked", "unknown"] },
          "path": { "type": "string", "minLength": 1 },
          "excerpt": { "type": "string", "maxLength": 1200 }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "name", "sizeBytes"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "sizeBytes": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["limitKind"],
      "properties": {
        "limitKind": { "enum": ["time", "token", "attempt", "command", "safety"] },
        "limit": { "type": "string", "minLength": 1, "maxLength": 300 },
        "used": { "type": "string", "minLength": 1, "maxLength": 300 },
        "reason": { "type": "string", "minLength": 1, "maxLength": 500 }
      }
    },
    "receiptTrace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion"],
      "properties": {
        "schemaVersion": { "const": "a2a.runner.receipt-trace.v1" },
        "outboxId": { "type": "string", "minLength": 1, "maxLength": 160 },
        "notificationId": { "type": "string", "minLength": 1, "maxLength": 160 },
        "dedupeKey": { "type": "string", "minLength": 1, "maxLength": 240 },
        "channel": { "type": "string", "minLength": 1, "maxLength": 60 },
        "status": { "enum": ["pending", "accepted", "started", "produced", "provider_sent", "operator_visible", "operator_confirmed", "provider_delivery_receipt", "timed_out", "stale", "failed", "receipt_confirmed"] },
        "evidence": { "enum": ["operator_visible", "operator_confirmed", "provider_delivery_receipt"] },
        "receiptId": { "type": "string", "minLength": 1, "maxLength": 160 },
        "acknowledgedAt": { "type": "string", "minLength": 1, "maxLength": 80 },
        "updatedAt": { "type": "string", "minLength": 1, "maxLength": 80 },
        "attemptCount": { "type": "integer", "minimum": 0 },
        "staleAfterMs": { "type": "integer", "minimum": 0 },
        "reason": { "type": "string", "minLength": 1, "maxLength": 300 }
      }
    },
    "continuation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["recommended", "requiresApproval"],
      "properties": {
        "recommended": { "type": "boolean" },
        "nextPrompt": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "requiresApproval": { "const": true }
      }
    },
    "evidenceHints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion"],
      "properties": {
        "schemaVersion": { "const": "a2a.runner.evidence-hints.v1" },
        "issueUrl": { "type": "string", "format": "uri" },
        "prUrl": { "type": "string", "format": "uri" },
        "doneUrl": { "type": "string", "format": "uri" },
        "blockUrl": { "type": "string", "format": "uri" },
        "branch": { "type": "string", "minLength": 1, "maxLength": 160 },
        "branchUrl": { "type": "string", "format": "uri" },
        "failureCategory": { "enum": ["pr", "done", "block", "budget_limited", "timed_out", "missing_evidence", "succeeded_no_changes_with_done_evidence", "blocked_no_changes_with_evidence", "failed_infrastructure", "failed", "exit_nonzero", "no_changes_allowed"] }
      }
    },
    "githubCommentProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "kind", "url", "manifestPath", "dedupeKey", "commentIsTerminalAck", "commentIsVisibilityReceipt", "commentIsOperatorApproval"],
      "properties": {
        "schemaVersion": { "const": "a2a.runner.github-comment-projection.v1" },
        "kind": { "enum": ["pr", "done", "block"] },
        "url": { "type": "string", "format": "uri" },
        "issueUrl": { "type": "string", "format": "uri" },
        "manifestPath": { "type": "string", "const": "artifacts/manifest.json" },
        "dedupeKey": { "type": "string", "minLength": 1, "maxLength": 300 },
        "commentIsTerminalAck": { "const": false },
        "commentIsVisibilityReceipt": { "const": false },
        "commentIsOperatorApproval": { "const": false }
      }
    },
    "sourcePublicApprovalRehearsal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "generatedAt", "decision", "approvalPackets", "terminalBriefRehearsalOnly", "replayNoDuplicateProof", "rollbackAbort", "safetyGates"],
      "properties": {
        "schemaVersion": { "const": "a2a.runner.source-public-approval-rehearsal.v1" },
        "generatedAt": { "const": "1970-01-01T00:00:00.000Z" },
        "runId": { "type": "string", "minLength": 1, "maxLength": 160 },
        "decision": { "enum": ["GO_CANDIDATE", "NO_GO", "NEEDS_OPERATOR_APPROVAL"] },
        "approvalPackets": {
          "type": "array",
          "minItems": 1,
          "maxItems": 10,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["schemaVersion", "packetId", "targetRepo", "decision", "dedupeKey", "evidenceBundlePath", "operatorApprovalRequired", "approvalExecuted", "releaseExecuted", "visibilityChanged", "terminalAckSent", "providerSendPerformed", "dbMutationPerformed", "rollbackPath", "abortPath"],
            "properties": {
              "schemaVersion": { "const": "a2a.runner.source-public-approval-packet.v1" },
              "packetId": { "type": "string", "minLength": 1, "maxLength": 120 },
              "targetRepo": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" },
              "decision": { "enum": ["GO_CANDIDATE", "NO_GO", "NEEDS_OPERATOR_APPROVAL"] },
              "dedupeKey": { "type": "string", "minLength": 1, "maxLength": 240 },
              "evidenceBundlePath": { "const": "artifacts/manifest.json" },
              "operatorApprovalRequired": { "const": true },
              "approvalExecuted": { "const": false },
              "releaseExecuted": { "const": false },
              "visibilityChanged": { "const": false },
              "terminalAckSent": { "const": false },
              "providerSendPerformed": { "const": false },
              "dbMutationPerformed": { "const": false },
              "rollbackPath": { "type": "string", "minLength": 1, "maxLength": 160 },
              "abortPath": { "type": "string", "minLength": 1, "maxLength": 160 }
            }
          }
        },
        "terminalBriefRehearsalOnly": { "const": true },
        "replayNoDuplicateProof": {
          "type": "object",
          "additionalProperties": false,
          "required": ["dedupeKey", "noDuplicatePacketIds"],
          "properties": {
            "dedupeKey": { "type": "string", "minLength": 1, "maxLength": 240 },
            "noDuplicatePacketIds": { "const": true }
          }
        },
        "rollbackAbort": {
          "type": "object",
          "additionalProperties": false,
          "required": ["rollbackPath", "abortPath"],
          "properties": {
            "rollbackPath": { "type": "string", "minLength": 1, "maxLength": 160 },
            "abortPath": { "type": "string", "minLength": 1, "maxLength": 160 }
          }
        },
        "safetyGates": {
          "type": "object",
          "additionalProperties": false,
          "required": ["operatorApprovalRequired", "sourcePublicExecutionBlocked", "approvalExecuted", "releaseExecuted", "visibilityChanged", "liveProviderSendPerformed", "terminalAckSent", "dbMutationPerformed"],
          "properties": {
            "operatorApprovalRequired": { "const": true },
            "sourcePublicExecutionBlocked": { "const": true },
            "approvalExecuted": { "const": false },
            "releaseExecuted": { "const": false },
            "visibilityChanged": { "const": false },
            "liveProviderSendPerformed": { "const": false },
            "terminalAckSent": { "const": false },
            "dbMutationPerformed": { "const": false }
          }
        }
      }
    },
    "sourcePublicExecutionPreflight": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "generatedAt", "mode", "status", "approvedPacket", "scannerHistoryBinding", "executionPlan", "replayProtection", "rollbackAbortRunbook", "preflightFailureSemantics", "safetyGates"],
      "properties": {
        "schemaVersion": { "const": "a2a.runner.source-public-execution-preflight.v1" },
        "generatedAt": { "const": "1970-01-01T00:00:00.000Z" },
        "runId": { "type": "string", "minLength": 1, "maxLength": 160 },
        "mode": { "enum": ["dry_run", "simulate"] },
        "status": { "enum": ["ready_for_operator_approval", "blocked"] },
        "approvedPacket": {
          "type": "object",
          "additionalProperties": false,
          "required": ["schemaVersion", "packetId", "targetRepo", "decision", "dedupeKey", "evidenceBundlePath"],
          "properties": {
            "schemaVersion": { "const": "a2a.runner.source-public-approval-packet.v1" },
            "packetId": { "type": "string", "minLength": 1, "maxLength": 120 },
            "targetRepo": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" },
            "decision": { "enum": ["GO_CANDIDATE", "NO_GO", "NEEDS_OPERATOR_APPROVAL"] },
            "dedupeKey": { "type": "string", "minLength": 1, "maxLength": 240 },
            "evidenceBundlePath": { "const": "artifacts/manifest.json" }
          }
        },
        "scannerHistoryBinding": {
          "type": "object",
          "additionalProperties": false,
          "required": ["scanProfileSchemaVersion", "scannerBound", "historyRunCount", "evidenceBundlePath", "manifestDigest", "historyDigest"],
          "properties": {
            "scanProfileSchemaVersion": { "const": "a2a.runner.scan-profile.v1" },
            "scannerBound": { "const": true },
            "historyRunCount": { "type": "integer", "minimum": 0 },
            "evidenceBundlePath": { "const": "artifacts/manifest.json" },
            "manifestDigest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "historyDigest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
          }
        },
        "executionPlan": {
          "type": "object",
          "additionalProperties": false,
          "required": ["planId", "planDedupeKey", "operatorGate", "dryRunOnly", "simulateOnly", "liveExecutionBlocked", "approvalExecutionBlocked", "replayProtected", "actions"],
          "properties": {
            "planId": { "type": "string", "minLength": 1, "maxLength": 120 },
            "planDedupeKey": { "type": "string", "minLength": 1, "maxLength": 300 },
            "operatorGate": { "const": "explicit_operator_approval_required" },
            "dryRunOnly": { "const": true },
            "simulateOnly": { "type": "boolean" },
            "liveExecutionBlocked": { "const": true },
            "approvalExecutionBlocked": { "const": true },
            "replayProtected": { "const": true },
            "actions": {
              "type": "array",
              "minItems": 1,
              "maxItems": 12,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["sequence", "id", "label", "targetRepo", "requiresExplicitOperatorApproval", "dryRunOnly", "sideEffectPerformed"],
                "properties": {
                  "sequence": { "type": "integer", "minimum": 1, "maximum": 99 },
                  "id": { "type": "string", "minLength": 1, "maxLength": 80 },
                  "label": { "type": "string", "minLength": 1, "maxLength": 180 },
                  "targetRepo": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" },
                  "requiresExplicitOperatorApproval": { "const": true },
                  "dryRunOnly": { "const": true },
                  "sideEffectPerformed": { "const": false }
                }
              }
            }
          }
        },
        "replayProtection": {
          "type": "object",
          "additionalProperties": false,
          "required": ["idempotencyKey", "inputFingerprint", "replayIndex", "duplicateDetected"],
          "properties": {
            "idempotencyKey": { "type": "string", "minLength": 1, "maxLength": 300 },
            "inputFingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "replayIndex": { "type": "integer", "minimum": 0 },
            "duplicateDetected": { "type": "boolean" }
          }
        },
        "rollbackAbortRunbook": {
          "type": "object",
          "additionalProperties": false,
          "required": ["rollbackSteps", "abortSteps"],
          "properties": {
            "rollbackSteps": { "type": "array", "minItems": 1, "maxItems": 8, "items": { "type": "string", "minLength": 1, "maxLength": 240 } },
            "abortSteps": { "type": "array", "minItems": 1, "maxItems": 8, "items": { "type": "string", "minLength": 1, "maxLength": 240 } }
          }
        },
        "preflightFailureSemantics": {
          "type": "object",
          "additionalProperties": false,
          "required": ["failClosed", "reasons", "approvalPacketNotGoCandidate", "missingScannerHistory", "manifestMismatch"],
          "properties": {
            "failClosed": { "const": true },
            "reasons": { "type": "array", "maxItems": 10, "items": { "type": "string", "maxLength": 220 } },
            "approvalPacketNotGoCandidate": { "type": "boolean" },
            "missingScannerHistory": { "type": "boolean" },
            "manifestMismatch": { "type": "boolean" }
          }
        },
        "safetyGates": {
          "type": "object",
          "additionalProperties": false,
          "required": ["operatorApprovalRequired", "sourcePublicExecutionBlocked", "approvalExecuted", "releaseExecuted", "visibilityChanged", "liveProviderSendPerformed", "terminalAckSent", "dbMutationPerformed", "deployOrRestartPerformed"],
          "properties": {
            "operatorApprovalRequired": { "const": true },
            "sourcePublicExecutionBlocked": { "const": true },
            "approvalExecuted": { "const": false },
            "releaseExecuted": { "const": false },
            "visibilityChanged": { "const": false },
            "liveProviderSendPerformed": { "const": false },
            "terminalAckSent": { "const": false },
            "dbMutationPerformed": { "const": false },
            "deployOrRestartPerformed": { "const": false }
          }
        }
      }
    }
  }
}
