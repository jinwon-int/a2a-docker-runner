  "baseBranch": "main",
  "commands": [
    "cd /work/repo && printf '## Canonical A2A Task Smoke\\n\\nRunner version: %s\\nNode: %s\\n' \"$(node --version)\" \"$(uname -n)\" > /work/artifacts/canonical-smoke.md",
    "cd /work/repo && cat /work/artifacts/canonical-smoke.md",
